## CODE GENERATION PATTERNS

### When generating a Controller method:
```php
// Thin controller — delegate to service
public function endorse(ApprovalActionRequest $request, Research $research): RedirectResponse
{
    $this->authorize('endorse', $research);
    $this->approvalService->endorse($research, auth()->user(), $request->remarks);
    return redirect()->route('approval.queue')->with('success', 'Research endorsed to OVPRI.');
}
```

### When generating a Service method:
```php
// Always use DB::transaction(), always dispatch jobs outside the transaction
public function endorse(Research $research, User $dean, ?string $remarks = null): void
{
    DB::transaction(function () use ($research, $dean, $remarks) {
        $research->update(['approval_stage' => 'ovpri_review']);
        Approval::create([
            'research_id' => $research->id,
            'approver_id' => $dean->id,
            'stage'       => 'dean',
            'action'      => 'endorsed',
            'remarks'     => $remarks,
            'acted_at'    => now(),
        ]);
        AuditLog::create([
            'user_id'        => $dean->id,
            'action'         => 'approval.endorsed',
            'auditable_type' => Research::class,
            'auditable_id'   => $research->id,
            'new_values'     => ['approval_stage' => 'ovpri_review'],
            'ip_address'     => request()->ip(),
        ]);
    });
    // Dispatch AFTER transaction commits
    SendNotificationJob::dispatch($research, 'endorsed');
}
```

